{
  "name": "morgu",
  "version": "0.1.0",
  "description": "Morgu — a premium React component library with Tailwind v4, Framer Motion & Lucide icons. Animated, themeable (dark/light), and fully typed.",
  "type": "module",
  "main": "./dist/morgu.umd.js",
  "module": "./dist/morgu.es.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./dist/morgu.es.js",
      "require": "./dist/morgu.umd.js"
    },
    "./styles.css": "./dist/morgu.css",
    "./dist/morgu.css": "./dist/morgu.css"
  },
  "files": [
    "dist",
    "index.d.ts",
    "README.md"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "vercel-install": "npm install --legacy-peer-deps",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "react",
    "component-library",
    "ui",
    "tailwindcss",
    "tailwind-v4",
    "framer-motion",
    "design-system",
    "morgu"
  ],
  "author": "Mustapha Adegbite <adegbitemustapha247@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Genius-mu/component-library.git"
  },
  "peerDependencies": {
    "framer-motion": "^11.0.0 || ^12.0.0",
    "lucide-react": "^0.400.0 || ^0.500.0 || ^0.600.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "tailwindcss": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "framer-motion": {
      "optional": true
    },
    "lucide-react": {
      "optional": true
    },
    "tailwindcss": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@tailwindcss/vite": "^4.1.18",
    "@vitejs/plugin-react": "^4.3.1",
    "eslint": "^9.9.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "framer-motion": "^11.18.2",
    "globals": "^17.6.0",
    "lucide-react": "^0.400.0",
    "react-router-dom": "^7.13.0",
    "vite": "^5.4.8",
    "vite-plugin-dts": "^4.5.4"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "ogl": "^1.0.11",
    "three": "^0.184.0"
  }
}
